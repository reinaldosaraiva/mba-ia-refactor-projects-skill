# Required: Flask session signing key (no default — boot fails fast if missing).
SECRET_KEY=change-me-to-a-random-32-byte-string

# Optional Flask flags.
DEBUG=false
HOST=0.0.0.0
PORT=5000

# SQLAlchemy connection. Defaults to a local SQLite file at sqlite:///tasks.db.
DATABASE_URI=sqlite:///tasks.db

# Optional SMTP credentials. NotificationService no-ops when SMTP_USER or
# SMTP_PASSWORD are empty, so dev environments can leave them blank.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
